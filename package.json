{
  "name": "education-advisor-tauri",
  "productName": "Education Advisor",
  "version": "0.1.0-rc.1",
  "description": "Education Advisor — Tauri 2 desktop edition of the multi-agent education management system. 18 specialized agents, privacy-preserving PII engine, cross-platform LLM orchestration, Rust data engine, all in a native Tauri shell with a Node.js sidecar.",
  "private": false,
  "type": "module",
  "author": {
    "name": "Education Advisor AI Contributors",
    "url": "https://github.com/232252/education-advisor-tauri"
  },
  "license": "MIT",
  "homepage": "https://github.com/232252/education-advisor-tauri#readme",
  "bugs": {
    "url": "https://github.com/232252/education-advisor-tauri/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/232252/education-advisor-tauri.git",
    "directory": "."
  },
  "keywords": [
    "ai",
    "agent",
    "education",
    "tauri",
    "desktop",
    "multi-agent",
    "llm",
    "privacy",
    "rust",
    "sidecar",
    "openclaw"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently -n MAIN,RENDERER -c blue,green \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "vite build --config vite.config.main.ts --watch",
    "dev:renderer": "vite --config vite.config.renderer.ts",
    "prebuild": "node scripts/prebuild-check.mjs",
    "build": "vite build --config vite.config.main.ts && vite build --config vite.config.renderer.ts",
    "build:icon": "node scripts/build-icon.mjs",
    "build:eaa": "node scripts/build-eaa.mjs",
    "build:sidecar": "vite build --config vite.config.sidecar.ts",
    "build:tauri": "npm run build:sidecar && node scripts/copy-sidecar-deps.mjs && npm run build",
    "tauri": "tauri",
    "tauri:dev": "npm run build:sidecar && tauri dev",
    "tauri:build": "npm run build:tauri && tauri build",
    "prebuild:check": "node scripts/prebuild-check.mjs",
    "self-check": "node scripts/self-check.cjs",
    "rollback:vendor": "node scripts/rollback-vendor.mjs",
    "verify:vendor": "node scripts/verify-vendor.mjs",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "file:./vendor/pi-agent-core",
    "@earendil-works/pi-ai": "file:./vendor/pi-ai",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@tauri-apps/api": "^2.11.1",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "node-cron": "^4.6.0",
    "typebox": "1.1.38",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@tanstack/react-table": "^8.20.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "ws": "^8.21.0",
    "zustand": "^5.0.2"
  },
  "allowScripts": {
    "better-sqlite3": true
  }
}
