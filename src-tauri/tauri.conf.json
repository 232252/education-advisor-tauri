{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Education Advisor",
  "version": "0.1.0",
  "identifier": "com.educationadvisor.tauri",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Education Advisor",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.openai.com https://api.deepseek.com https://open.feishu.cn http://127.0.0.1:11434 https://api.moonshot.cn https://api.anthropic.com https://generativelanguage.googleapis.com https://api.minimax.chat ws://localhost:5173 http://localhost:5173",
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../config",
      "../resources/eaa-binaries",
      "../agents",
      "../sidecar",
      "../dist/sidecar",
      "../dist/main",
      "../vendor/pi-ai/dist",
      "../vendor/pi-ai/package.json",
      "../package.json",
      "../package-lock.json"
    ],
    "copyright": "MIT",
    "category": "Education",
    "shortDescription": "Multi-agent education management desktop app",
    "longDescription": "Education Advisor — the desktop edition of the open-source multi-agent education management system, migrated to Tauri."
  },
  "plugins": {}
}
